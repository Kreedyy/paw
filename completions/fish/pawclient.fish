complete -c pawclient -x                            -a "(__fish_complete_subcommand)"
complete -c pawclient -x -s t -l term               -a '(find /usr/share/terminfo -type f -printf "%f\n")' -d "value to set the environment variable TERM to (paw)"
complete -c pawclient -x -s T -l title                                                                     -d "initial window title"
complete -c pawclient -x -s a -l app-id                                                                    -d "value to set the app-id property on the Wayland window to (paw)"
complete -c pawclient -x      -l toplevel-tag                                                              -d "value to set the toplevel-tag property on the Wayland window to"
complete -c pawclient    -s m -l maximized                                                                 -d "start in maximized mode"
complete -c pawclient    -s F -l fullscreen                                                                -d "start in fullscreen mode"
complete -c pawclient    -s L -l login-shell                                                               -d "start shell as a login shell"
complete -c pawclient -F -s D -l working-directory                                                         -d "initial working directory for the client application (CWD)"
complete -c pawclient -x -s w -l window-size-pixels                                                        -d "window WIDTHxHEIGHT, in pixels (700x500)"
complete -c pawclient -x -s W -l window-size-chars                                                         -d "window WIDTHxHEIGHT, in characters (not set)"
complete -c pawclient -F -s s -l server-socket                                                             -d "override the default path to the paw server socket ($XDG_RUNTIME_DIR/paw-$WAYLAND_DISPLAY.sock)"
complete -c pawclient    -s H -l hold                                                                      -d "remain open after child process exits"
complete -c pawclient    -s N -l no-wait                                                                   -d "detach the client process from the running terminal, exiting immediately"
complete -c pawclient -x -s o -l override                                                                  -d "configuration option to override, in form SECTION.KEY=VALUE"
complete -c pawclient    -s E -l client-environment                                                        -d "child process inherits pawclient's environment, instead of the server's"
complete -c pawclient -x -s d -l log-level          -a "info warning error none"                           -d "log-level (info)"
complete -c pawclient -x -s l -l log-colorize       -a "always never auto"                                 -d "enable or disable colorization of log output on stderr"
complete -c pawclient    -s v -l version                                                                   -d "show the version number and quit"
complete -c pawclient    -s h -l help                                                                      -d "show help message and quit"
